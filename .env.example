# ============================================================
# GOOGLE SHEETS
# ============================================================
# Google 서비스 계정 JSON 키 파일 경로 (로컬 개발용)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./secrets/google-service-account.json

# CI/CD용 base64 인코딩 버전 (GitHub Secrets에 저장)
# base64 인코딩 방법: base64 -w 0 google-service-account.json
# GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# 구글 스프레드시트 ID (URL에서 확인)
# https://docs.google.com/spreadsheets/d/<여기>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=1shkSCn2od2e5NOOPSASZYIS-THQkDk9wf_Crkk1h-2U

# 탭 이름
GOOGLE_SHEETS_OUTPUT_TAB=Slack
GOOGLE_SHEETS_LOG_TAB=Slack 로그

# ============================================================
# SLACK
# ============================================================
SLACK_BOT_TOKEN=xoxb-...

# 수집할 채널 ID (단일 채널)
SLACK_TARGET_CHANNEL_ID=C0123456789

# 제외할 유저 ID (쉼표 구분, 선택사항)
# SLACK_EXCLUDED_USER_IDS=

# ============================================================
# SYNC 설정
# ============================================================
# 첫 실행 시 과거 몇 일치를 가져올지
# 0 = 전체 히스토리, 숫자 = 해당 일수만큼
SYNC_INITIAL_LOOKBACK_DAYS=0

# 전체 재수집 여부 (true 이면 전체, false 이면 증분)
FORCE_FULL_SYNC=false

# 실제로 시트에 쓰지 않고 로그만 (테스트용)
# DRY_RUN=true

# ============================================================
# 공통
# ============================================================
LOG_LEVEL=info
LOG_FORMAT=pretty
NODE_ENV=development
