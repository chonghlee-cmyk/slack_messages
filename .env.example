# ============================================================
# GOOGLE SHEETS
# ============================================================
# Google 서비스 계정 JSON 키 파일 경로 (로컬 개발용)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./secrets/google-service-account.json

# CI/CD용 base64 인코딩 버전 (GitHub Secrets에 저장)
# base64 인코딩 방법: base64 -w 0 google-service-account.json
# GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# 구글 스프레드시트 ID (URL에서 확인)
# https://docs.google.com/spreadsheets/d/<여기>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# 탭 이름
GOOGLE_SHEETS_ARTWORK_TAB=작품관리대장 2.0
GOOGLE_SHEETS_OUTPUT_TAB=Slack

# 작품명이 있는 열 번호 (0 = A열, 1 = B열, ...)
GOOGLE_SHEETS_ARTWORK_NAME_COLUMN=0

# ============================================================
# SLACK (Phase 1에서 추가)
# ============================================================
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_WORKSPACE_DOMAIN=yourworkspace
# SLACK_TARGET_CHANNEL_IDS=C0123456789,C9876543210
# SLACK_EXCLUDED_USER_IDS=

# ============================================================
# SUPABASE (Phase 2에서 추가)
# ============================================================
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================================
# SYNC 설정 (Phase 1에서 추가)
# ============================================================
# SYNC_INITIAL_LOOKBACK_DAYS=90
# SLACK_SEARCH_PAGE_SIZE=20
# SYNC_CONCURRENCY=2
# SYNC_ARTWORK_DELAY_MS=1000

# ============================================================
# 공통
# ============================================================
LOG_LEVEL=info
LOG_FORMAT=pretty
NODE_ENV=development
